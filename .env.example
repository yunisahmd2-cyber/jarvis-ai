# App
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Core backend
DATABASE_URL=sqlite:////absolute/path/to/jarvis-ai/backend/data/jarvis.db
LLM_PRIMARY_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
MISTRAL_API_KEY=
FRONTEND_BACKEND_URL=http://127.0.0.1:8000

# Frontend runtime
VITE_BACKEND_BASE_URL=http://127.0.0.1:8000
VITE_BACKEND_WS_URL=ws://127.0.0.1:8000/ws

# Speech and voice
STT_PROVIDER=faster-whisper
TTS_PROVIDER=edge
DEFAULT_VOICE_NAME=Daniel
EDGE_VOICE_NAME=en-GB-RyanNeural
FAST_EDGE_VOICE_NAME=en-US-GuyNeural
PIPER_MODEL_PATH=/absolute/path/to/jarvis-ai/piper_voices/en_GB-alan-medium.onnx
WHISPER_MODEL_NAME=base
WHISPER_BASIC_MODEL_NAME=tiny
WHISPER_ADVANCED_MODEL_NAME=base
WHISPER_COMPUTE_TYPE=int8
STT_DEFAULT_LANGUAGE=en
STT_AUTO_DETECT_LANGUAGE=false
AUDIO_INPUT_DEVICE=

# Voice capture tuning
SPEECH_MAX_SECONDS=8.5
SPEECH_SILENCE_SECONDS=0.62
SPEECH_MIN_SPEECH_SECONDS=0.24
SPEECH_SILENCE_THRESHOLD=0.009

# Wake word and reminders
WAKE_WORD=jarvis
REMINDER_POLL_SECONDS=20
WAKE_WORD_LOAD_THRESHOLD_RATIO=0.8

# Safety and integrations
REQUIRE_CONFIRMATION_FOR_RISKY_ACTIONS=true
ALLOWED_APPS=Safari,Spotify,Finder,Terminal,Notes,TextEdit,Music,Messages,Google Chrome,Arc,Calculator,Preview,Visual Studio Code,Mail,Calendar,Reminders,System Settings,Photos,Slack,Discord,zoom.us
SPOTIFY_ENABLED=true
OCR_ENABLED=false
SCREEN_ANALYSIS_ENABLED=false
