{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jarvis",
  "version": "0.1.0",
  "identifier": "com.jarvis.app",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jarvis",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
